# Django
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-with-django-or-openssl

# Banco de dados (se PostreSQL)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=printcollor
# DB_USER=printcollor_user
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# CORS
